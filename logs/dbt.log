  create view "ecosave_local"."public_staging"."stg_client_meters_enriched__dbt_tmp"
    
    
  as (
    

SELECT
    l.meterid,
    l.clientid,
    l.sold_date,
    l.meter_status,
    l.mpan,
    l.timestamp,
    l.removed,
    l.ced,
    l.meter_postcode,
    l.meter_type,
