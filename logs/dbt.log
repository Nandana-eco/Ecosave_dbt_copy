  create  table "ecosave_local"."public_staging"."stg_tracker_main_data__dbt_tmp"
  
  
    as
  
  (
    

WITH ranked AS (

    SELECT
        rowid,
        clientid,
        mpan,
        supplier_to,
        meter_value,
        contract_duration,
        row_add_date,
        account_manager,
        lead_gen_agent,
        closer,

        -- ✅ standardised columns
        --UPPER(TRIM(ecosave_status)) AS ecosave_status,
        supplier_status AS supplier_status,
        mapped_supplier_status as ecosave_status,
        UPPER(TRIM(team)) AS team,

        supplier_csd,
        ROW_NUMBER() OVER (
            PARTITION BY mpan
            ORDER BY row_add_date DESC
        ) AS rn

    FROM "ecosave_local"."raw"."tracker_main_data"
     

)

SELECT *
FROM ranked
--where rn = 1
  );
  
